# ─────────────────────────────────────────────────────────
# VICCOM ECOMMERCE - Variables de Entorno
# ─────────────────────────────────────────────────────────
# Copia este archivo como .env.local y completa los valores

# ─── SUPABASE ────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://tu-proyecto.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=tu_anon_key_aqui
SUPABASE_SERVICE_ROLE_KEY=tu_service_role_key_aqui

# ─── SITIO ───────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://www.viccom.mx
NEXT_PUBLIC_SITE_NAME=VICCOM - Distribuidor de Equipos de Cómputo
NEXT_PUBLIC_WHATSAPP_NUMBER=529611209361
NEXT_PUBLIC_EMPRESA_TELEFONO=961 120 93 61
NEXT_PUBLIC_EMPRESA_CORREO=vic_computo@hotmail.com
NEXT_PUBLIC_WHATSAPP_MESSAGE=Hola, me interesa cotizar el siguiente producto:

# ─── ADMIN ───────────────────────────────────────────────
ADMIN_SECRET_KEY=cambia_esta_clave_secreta_larga_y_aleatoria

# ─── VPS BACKEND SYNC (llamadas internas) ────────────────
# URL del servicio de sincronización en el VPS
SYNC_SERVICE_URL=http://TU_IP_FIJA:3001
SYNC_SERVICE_SECRET=clave_secreta_compartida_con_vps

# BACKEND SYNC SERVICE (VPS)
# Estas variables viven en backend/.env cuando el servicio corre en el VPS.
SUPABASE_URL=https://tu-proyecto.supabase.co
SYNC_SECRET=misma_clave_que_SYNC_SERVICE_SECRET
ALLOWED_ORIGIN=https://www.viccom.mx
PORT=3001
LOG_LEVEL=info

# CT INTERNACIONAL
CT_API_URL=https://api.ctinternacional.com/catalogo.json
CT_API_TOKEN=tu_token_ct
CT_FTP_HOST=ftp.ctinternacional.com
CT_FTP_USER=tu_usuario_ct
CT_FTP_PASS=tu_password_ct
CT_FTP_PATH=/

