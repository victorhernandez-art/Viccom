    "express":              "^4.21.2",
    "node-cron":            "^3.0.3",
    "winston":              "^3.17.0"
  },
  "devDependencies": {
    "@types/cors":      "^2.8.17",
    "@types/express":   "^5.0.3",
    "@types/node":      "^22.15.30",
    "@types/node-cron": "^3.0.11",
    "ts-node-dev":      "^2.0.0",
    "typescript":       "^5.8.3"
  },
  "engines": {
    "node": ">=20.0.0"
