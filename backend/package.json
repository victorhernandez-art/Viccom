{
  "name": "viccom-sync-service",
  "version": "1.0.0",
  "description": "VPS sync service for CT Connect catalog integration",
  "main": "dist/index.js",
  "scripts": {
    "dev":   "ts-node-dev --respawn --transpile-only src/index.ts",
