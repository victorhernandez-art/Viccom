# CT Connect JSON API credentials
CT_API_URL=https://api.ctinternacional.com/catalogo.json
CT_API_TOKEN=your_api_token

# CT Connect FTP credentials (fallback si CT_API_URL no esta configurado)
CT_FTP_HOST=ftp.ctonline.mx
CT_FTP_USER=your_ftp_user
CT_FTP_PASS=your_ftp_password
CT_FTP_PATH=/

# Supabase credentials (service role — keep secret!)
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Backend server
PORT=3001
NODE_ENV=production
LOG_LEVEL=info

# Authentication secret for API calls from Next.js
SYNC_SECRET=your_sync_secret_key_here

# Allowed CORS origin (set to your frontend URL)
ALLOWED_ORIGIN=https://viccom.com.mx
